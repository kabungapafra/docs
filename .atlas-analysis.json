  "keyFeatures": [
    "JWT-based authentication with Firebase Phone Auth support",
    "Group-based savings management (chama/savings circle)",
    "Contribution tracking with credit score impact",
    "Loan requests with eligibility checks (3x savings rule)",
    "Multi-admin unanimous approval workflow for loans, transactions, and payouts",
    "Automated payout queue ordered by member credit scores",
    "Savings cycle management with contribution due dates",
    "Push notifications via Firebase Cloud Messaging",
    "Configurable financial rules (interest rates, loan limits, retention)",
    "Audit logging for all admin actions"
  ],
